{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "name": "grandmaster-chess-ai",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}